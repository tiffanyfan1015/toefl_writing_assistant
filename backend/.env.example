# Copy this file to `.env` and fill in real values:
#   cp .env.example .env
#
# Generate a random local API key (prints to terminal; add --write to update .env files):
#   npm run generate-api-key
#   npm run generate-api-key -- --write
#
# Do not commit `.env` — it may contain secrets.

# --- Database (Prisma / SQLite) ---
# Path to the SQLite file used in development.
# Relative paths are resolved from the `backend/` directory.
DATABASE_URL="file:./dev.db"

# --- Google Gemini (essay grading & auto-generate prompts) ---
# API key from Google AI Studio: https://aistudio.google.com/apikey
# Required at startup; the server will exit if this is missing.
GEMINI_API_KEY="YOUR-GEMINI-API-KEY-HERE"

# Model configuration for generate/evaluate calls.
# You can provide a comma-separated list of models to allow switching in the UI.
# The first model in GEMINI_MODEL_OPTIONS (or GEMINI_MODEL_DEFAULT) will be the default.
GEMINI_MODEL_OPTIONS="gemini-flash-latest,gemini-3.1-flash-lite"
GEMINI_MODEL_DEFAULT="gemini-flash-latest"

# --- HTTP API security ---
# Shared secret for `Authorization: Bearer <API_KEY>` on all `/api/*` routes.
# Must match the frontend `VITE_API_KEY` in `frontend/.env`.
API_KEY="your-local-api-key"

# Browser origin allowed by CORS (Vite dev server by default).
# Use your production frontend URL when deploying.
ALLOWED_ORIGIN="http://localhost:5173"

# --- Server bind ---
# Listen address. Use 127.0.0.1 for local-only; 0.0.0.0 if other machines must reach the API.
BIND_ADDRESS="127.0.0.1"

# TCP port for the Express server.
PORT=3001

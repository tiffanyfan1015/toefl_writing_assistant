// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Question {
  id          Int          @id @default(autoincrement())
  type        String       // "Email" or "Academic"
  title       String
  content     String
  submissions Submission[]
  createdAt   DateTime     @default(now())
}

model Submission {
  id          Int                  @id @default(autoincrement())
  questionId  Int
  question    Question             @relation(fields: [questionId], references: [id])
  currentText String
  latestScore Float?
  revisions   SubmissionRevision[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

model SubmissionRevision {
  id           Int        @id @default(autoincrement())
  submissionId Int
  submission   Submission @relation(fields: [submissionId], references: [id])
  text         String
  score        Float?
  feedback     String?
  errorLogs    ErrorLog[] // Moved here
  createdAt    DateTime   @default(now())
}

model ErrorLog {
  id           Int                @id @default(autoincrement())
  revisionId   Int                // Changed from submissionId
  revision     SubmissionRevision @relation(fields: [revisionId], references: [id])
  errorType    String             // "Grammar", "Spelling", etc.
  incorrect    String
  suggestion   String
  explanation  String?
  important    Boolean            @default(false)
  createdAt    DateTime           @default(now())
}

model SpeakingQuestion {
  id           Int                @id @default(autoincrement())
  title        String
  introduction String
  question1    String
  question2    String
  question3    String
  question4    String
  sessions     SpeakingSession[]
  createdAt    DateTime           @default(now())
}

model SpeakingSession {
  id         Int                   @id @default(autoincrement())
  questionId Int
  question   SpeakingQuestion      @relation(fields: [questionId], references: [id])
  parts      SpeakingAttemptPart[]
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
}

model SpeakingAttemptPart {
  id            Int                  @id @default(autoincrement())
  sessionId     Int
  session       SpeakingSession      @relation(fields: [sessionId], references: [id])
  partIndex     Int
  audioPath     String
  audioMimeType String?
  transcript    String
  score         Float?
  feedback      String?
  errorLogs     SpeakingErrorLog[]
  createdAt     DateTime             @default(now())

  @@unique([sessionId, partIndex])
}

model SpeakingErrorLog {
  id          Int                 @id @default(autoincrement())
  partId      Int
  part        SpeakingAttemptPart @relation(fields: [partId], references: [id])
  errorType   String
  incorrect   String
  suggestion  String
  explanation String?
  important   Boolean             @default(false)
  createdAt   DateTime            @default(now())
}
